# App
OPENIBEX_ENV=development
NODE_ENV=development
PORT=3000

# SQLite (Drizzle Kit expects DATABASE_URL)
# Local dev default (relative path):
DATABASE_URL=file:./data/openibex.db

# Filesystem data roots (bind-mount /data in Docker)
OPENIBEX_DATA_DIR=./data
OPENIBEX_UPLOAD_DIR=./data/uploads
OPENIBEX_STREAM_DIR=./data/streams
OPENIBEX_EXPORT_DIR=./data/exports
OPENIBEX_IMPORT_DIR=./data/imports

# Founder decision (used in Milestone 1+)
OPEN_REGISTRATION=false

# Auth (Milestone 1)
# Set a long random value in production (32+ bytes).
# In non-production modes, OpenIbex will fall back to an insecure dev secret if unset.
SESSION_SECRET=
SESSION_TTL_DAYS=30

# Canonical origin for the production Node server (adapter-node).
# Required so SvelteKit's CSRF check accepts your login/upload form POSTs.
# Defaults to http://localhost:3000 in docker-compose.yml. Set to your full
# https URL when behind a reverse proxy (e.g. https://openibex.example.com).
ORIGIN=http://localhost:3000

# Experimental Garmin Connect sync (optional).
# Encrypts the Garmin session tokens stored per user (AES-256-GCM). Required
# ONLY if you connect a Garmin account in Settings → Integrations; the app boots
# fine without it. Generate a fresh 32-byte key:
#   openssl rand -base64 32
# WARNING: if you lose/rotate this value, stored tokens become unreadable and
# every connected user must reconnect.
SYNC_ENCRYPTION_KEY=
