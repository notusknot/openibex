# App
# OpenIbex now treats an UNSET environment as production (fail-safe): set
# OPENIBEX_ENV/NODE_ENV to "development" only for local non-prod runs.
OPENIBEX_ENV=production
NODE_ENV=production
PORT=3000

# Local timezone for dashboard/calendar "local day" bucketing (IANA name, e.g.
# America/Los_Angeles, Europe/Berlin). If unset, the SERVER clock's zone is used
# — correct only if the container TZ matches the athlete's. Set this if you run
# in UTC (the Docker default) but train in another zone, otherwise evening
# workouts can land on the wrong day.
OPENIBEX_TZ=

# Logging: pino level — fatal|error|warn|info|debug|trace|silent. Default info.
# Logs are JSON on stdout; pipe through `pino-pretty` in dev for readability.
LOG_LEVEL=info

# SQLite (Drizzle Kit expects DATABASE_URL)
# Local dev default (relative path):
DATABASE_URL=file:./data/openibex.db

# Filesystem data roots (bind-mount /data in Docker)
OPENIBEX_DATA_DIR=./data
OPENIBEX_UPLOAD_DIR=./data/uploads
OPENIBEX_STREAM_DIR=./data/streams
OPENIBEX_EXPORT_DIR=./data/exports
OPENIBEX_IMPORT_DIR=./data/imports

# Founder decision (used in Milestone 1+)
OPEN_REGISTRATION=false

# Auth (Milestone 1)
# Set a long random value in production (32+ bytes).
# In non-production modes, OpenIbex will fall back to an insecure dev secret if unset.
SESSION_SECRET=
SESSION_TTL_DAYS=30

# Canonical origin for the production Node server (adapter-node).
# Required so SvelteKit's CSRF check accepts your login/upload form POSTs.
# Defaults to http://localhost:3000 in docker-compose.yml. Set to your full
# https URL when behind a reverse proxy (e.g. https://openibex.example.com).
ORIGIN=http://localhost:3000

# Experimental Garmin Connect sync (optional).
# Encrypts the Garmin session tokens stored per user (AES-256-GCM). Required
# ONLY if you connect a Garmin account in Settings → Integrations; the app boots
# fine without it. Generate a fresh 32-byte key:
#   openssl rand -base64 32
# WARNING: if you lose/rotate this value, stored tokens become unreadable and
# every connected user must reconnect.
SYNC_ENCRYPTION_KEY=

# Experimental calendar (ICS) subscription sync (optional — sane defaults shown).
# Feeds are polled opportunistically on page loads, throttled per subscription;
# there is no background worker. Tune only if a feed misbehaves.
#   CALENDAR_SYNC_THROTTLE_MS    min gap between auto-polls of one feed (15 min)
#   CALENDAR_SYNC_HORIZON_DAYS   how far ahead to materialize events (60)
#   CALENDAR_SYNC_PAST_GRACE_DAYS how far back to keep materializing (1)
#   CALENDAR_MAX_FEED_BYTES      reject feeds larger than this (5_000_000)
#   CALENDAR_FETCH_TIMEOUT_MS    abort a feed fetch after this long (15_000)
#   CALENDAR_MAX_OCCURRENCES     cap expanded occurrences per feed per poll (500)
CALENDAR_SYNC_THROTTLE_MS=900000
CALENDAR_SYNC_HORIZON_DAYS=60
CALENDAR_SYNC_PAST_GRACE_DAYS=1
CALENDAR_MAX_FEED_BYTES=5000000
CALENDAR_FETCH_TIMEOUT_MS=15000
CALENDAR_MAX_OCCURRENCES=500
