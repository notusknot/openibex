{
  "name": "openibex",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "import:garmin": "tsx scripts/import-garmin.ts",
    "analytics:rebuild": "tsx scripts/rebuild-daily-metrics.ts",
    "titles:backfill": "tsx scripts/backfill-activity-titles.ts",
    "cleanup:ghosts": "tsx scripts/cleanup-ghost-activities.ts",
    "audit": "pnpm audit --prod"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^2.0.0",
    "@sveltejs/kit": "^2.0.0",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "fit-file-parser": "^1.11.0",
    "garmin-connect": "1.6.2",
    "jszip": "^3.10.1",
    "pino": "^10.3.1",
    "svelte": "^4.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.31.10",
    "svelte-check": "^3.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
